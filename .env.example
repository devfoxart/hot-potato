# Copier ce fichier en `.env` et renseigner les vraies valeurs (jamais commit).
# Sans EXPO_PUBLIC_SENTRY_DSN, le crash reporting reste désactivé (no-op) : l'app
# fonctionne normalement mais aucune erreur n'est remontée.

# DSN du projet Sentry (créer un compte gratuit sur https://sentry.io puis un projet React Native)
EXPO_PUBLIC_SENTRY_DSN=

# Optionnel : pour que le plugin @sentry/react-native/expo upload les source maps
# lors des builds (sinon build normal mais stack traces non symbolisées).
# Pour le CI GitHub Actions, ajouter ces 3 valeurs comme secrets du repo
# (Settings > Secrets and variables > Actions) plutot que dans ce fichier :
# tant que SENTRY_AUTH_TOKEN n'est pas defini, le workflow desactive
# automatiquement l'upload (SENTRY_DISABLE_AUTO_UPLOAD).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
